# Copy to .env for local development (never commit .env)
# Render: set these as Environment Variables in the dashboard.

SPRING_PROFILES_ACTIVE=dev

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cloudshare?retryWrites=true&w=majority

# JWT — generate with: openssl rand -base64 64  (minimum 64 characters)
JWT_SECRET=<your-64-plus-character-random-secret>

# Optional JWT lifetimes (milliseconds)
JWT_ACCESS_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=2592000000

# Frontend URL (Vercel deployment URL in production)
APP_FRONTEND_URL=http://localhost:5173

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Auth behaviour
REQUIRE_EMAIL_VERIFICATION=false
DEV_EXPOSE_TOKENS=true
EXPOSE_ERROR_DETAILS=true

# Razorpay (use test keys locally, live keys in production)
RAZORPAY_KEY_ID=rzp_test_T1byiJE2Ok9Q8L
RAZORPAY_KEY_SECRET=5jSLTIkk5FOCiKw5316doIsE

# SMTP (optional — leave MAIL_HOST blank to log emails to console in dev)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=CloudShare <no-reply@yourdomain.com>

# File storage directory on the server
UPLOAD_DIR=upload
